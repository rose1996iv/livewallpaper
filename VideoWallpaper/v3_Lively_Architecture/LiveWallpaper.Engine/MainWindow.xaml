<Window x:Class="LiveWallpaper.Engine.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="VideoWallpaper"
        Background="Black"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        SourceInitialized="Window_SourceInitialized"
        Closed="Window_Closed">
    <Grid Background="Black">
        <!-- We stretch the VideoView uniformly to fill the background -->
        <vlc:VideoView x:Name="WallpaperPlayer" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
        <wv2:WebView2 x:Name="WebPlayer" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Visibility="Collapsed" />
    </Grid>
</Window>
