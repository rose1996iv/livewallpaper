<ui:FluentWindow x:Class="LiveWallpaper.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Control Panel"
        Height="550" Width="800"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom TitleBar using WPF-UI -->
        <ui:TitleBar x:Name="TitleBar" Grid.Row="0" Title="VideoWallpaper - Control Panel" />

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                <ui:Button Content="Change Video/HTML" Icon="FolderOpen24" Appearance="Primary" HorizontalAlignment="Stretch" Click="ChangeVideo_Click" Margin="0,0,0,10" />
                <ui:Button Content="Open Gallery" Icon="Image24" Appearance="Secondary" HorizontalAlignment="Stretch" Click="OpenGallery_Click" Margin="0,0,0,10" />
                <ui:Button Content="Stop / Exit" Icon="Power24" Appearance="Danger" HorizontalAlignment="Stretch" Click="Exit_Click" />
            </StackPanel>

            <Grid Grid.Column="1">
                <Border Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="8" Padding="20">
                    <StackPanel>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,30">
                            <ui:SymbolIcon Symbol="MoviesAndTv24" FontSize="48" Margin="0,0,0,10" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="Live Video Wallpaper" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <TextBlock Text="Manage your wallpaper video and preferences." Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Wallpaper Mode Section -->
                        <TextBlock Text="Wallpaper Type" FontWeight="SemiBold" Margin="0,0,0,10" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <RadioButton x:Name="VideoRadioButton" Content="Video File" Checked="VideoMode_Checked" Margin="0,0,20,0" />
                            <RadioButton x:Name="WebRadioButton" Content="Web Page (URL/HTML)" Checked="WebMode_Checked" />
                        </StackPanel>
                        
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox x:Name="UrlTextBox" PlaceholderText="https://www.shadertoy.com/..." Grid.Column="0" Margin="0,0,10,0"/>
                            <ui:Button Content="Set URL" Appearance="Secondary" Grid.Column="1" Click="SetWebUrl_Click"/>
                        </Grid>

                        <!-- Settings section -->
                        <TextBlock Text="Settings" FontWeight="SemiBold" Margin="0,0,0,10" />
                        
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Run on Windows Startup" VerticalAlignment="Center" />
                            <ui:ToggleSwitch x:Name="AutoStartSwitch" Grid.Column="1" Checked="AutoStartSwitch_Checked" Unchecked="AutoStartSwitch_Unchecked" />
                        </Grid>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Auto-Rotate Gallery Wallpapers" VerticalAlignment="Center" />
                            <ui:ToggleSwitch x:Name="AutoRotateSwitch" Grid.Column="1" Checked="AutoRotateSwitch_Checked" Unchecked="AutoRotateSwitch_Unchecked" />
                        </Grid>

                        <TextBlock Text="Rotation Interval (Minutes)" VerticalAlignment="Center" Margin="0,0,0,5" />
                        <Slider x:Name="RotateSlider" Minimum="1" Maximum="120" Value="15" ValueChanged="RotateSlider_ValueChanged" Margin="0,0,0,15" />

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Pause when a window is fullscreen (Games/Movies)" VerticalAlignment="Center" />
                            <ui:ToggleSwitch x:Name="PauseFullscreenSwitch" Grid.Column="1" Checked="PauseFullscreenSwitch_Checked" Unchecked="PauseFullscreenSwitch_Unchecked" />
                        </Grid>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Pause when on Battery power" VerticalAlignment="Center" />
                            <ui:ToggleSwitch x:Name="PauseBatterySwitch" Grid.Column="1" Checked="PauseBatterySwitch_Checked" Unchecked="PauseBatterySwitch_Unchecked" />
                        </Grid>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Mute Sound (Video Only)" VerticalAlignment="Center" />
                            <ui:ToggleSwitch x:Name="MuteSwitch" Grid.Column="1" Checked="MuteSwitch_Checked" Unchecked="MuteSwitch_Unchecked" />
                        </Grid>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Make Taskbar Transparent" VerticalAlignment="Center" />
                            <ui:ToggleSwitch x:Name="TaskbarSwitch" Grid.Column="1" Checked="TaskbarSwitch_Checked" Unchecked="TaskbarSwitch_Unchecked" />
                        </Grid>

                        <TextBlock Text="Volume" VerticalAlignment="Center" Margin="0,0,0,5" />
                        <Slider x:Name="VolumeSlider" Minimum="0" Maximum="100" Value="100" ValueChanged="VolumeSlider_ValueChanged" />
                        
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
