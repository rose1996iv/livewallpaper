<Window x:Class="WallpaperScreensaver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WallpaperScreensaver"
        Title="Wallpaper Screensaver" WindowStyle="None" WindowState="Maximized" 
        ResizeMode="NoResize" ShowInTaskbar="False" Topmost="True" Background="Black"
        KeyDown="Window_KeyDown" MouseMove="Window_MouseMove" MouseDown="Window_MouseDown">
