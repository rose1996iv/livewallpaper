<Window x:Class="WallpaperEngine.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wallpaper Engine Settings"
        Height="720"
        Width="1024"
        MinHeight="640"
        MinWidth="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,16">
            <TextBlock FontSize="24" FontWeight="SemiBold" Text="Wallpaper Engine" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="#666666"
                       Text="Production-style desktop wallpaper controller using WorkerW, MediaElement, and modular services." />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <GroupBox Header="Library and Layout" Padding="14" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Layout mode" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1"
                                  Margin="12,0,0,8"
                                  ItemsSource="{Binding LayoutModes}"
                                  SelectedItem="{Binding SelectedLayoutMode}" />

                        <TextBlock Grid.Row="1" Text="Default wallpaper" VerticalAlignment="Center" />
                        <ComboBox Grid.Row="1"
                                  Grid.Column="1"
                                  Margin="12,0,0,8"
                                  ItemsSource="{Binding Wallpapers}"
                                  SelectedItem="{Binding SelectedDefaultWallpaper}"
                                  DisplayMemberPath="DisplayName" />

                        <TextBlock Grid.Row="2" Text="Span wallpaper" VerticalAlignment="Center" />
                        <ComboBox Grid.Row="2"
                                  Grid.Column="1"
                                  Margin="12,0,0,8"
                                  ItemsSource="{Binding Wallpapers}"
                                  SelectedItem="{Binding SelectedSpanWallpaper}"
                                  DisplayMemberPath="DisplayName" />

                        <StackPanel Grid.Row="3"
                                    Grid.ColumnSpan="2"
                                    Margin="0,8,0,0"
                                    Orientation="Horizontal">
                            <Button Width="140"
                                    Margin="0,0,8,0"
                                    Content="Open Library"
                                    Command="{Binding OpenLibraryCommand}" />
                            <Button Width="140"
                                    Content="Refresh Library"
                                    Command="{Binding RefreshCommand}" />
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="1" Header="Playback" Padding="14" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Stretch mode" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1"
                                  Margin="12,0,0,8"
                                  ItemsSource="{Binding StretchModes}"
                                  SelectedItem="{Binding SelectedStretchMode}" />

                        <TextBlock Grid.Row="1" Text="Volume (0.0 - 1.0)" VerticalAlignment="Center" />
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="12,0,0,8" Text="{Binding Volume}" />

                        <TextBlock Grid.Row="2" Text="Playback speed" VerticalAlignment="Center" />
                        <TextBox Grid.Row="2" Grid.Column="1" Margin="12,0,0,8" Text="{Binding PlaybackSpeed}" />

                        <WrapPanel Grid.Row="3" Grid.ColumnSpan="2" Margin="0,8,0,0">
                            <CheckBox Margin="0,0,18,8" Content="Mute audio" IsChecked="{Binding IsMuted}" />
                            <CheckBox Margin="0,0,18,8" Content="Maintain aspect ratio" IsChecked="{Binding MaintainAspectRatio}" />
                            <CheckBox Margin="0,0,18,8" Content="Use hardware acceleration" IsChecked="{Binding UseHardwareAcceleration}" />
                            <CheckBox Margin="0,0,18,8" Content="Pause on full-screen apps" IsChecked="{Binding PauseOnFullscreen}" />
                            <CheckBox Margin="0,0,18,8" Content="Start with Windows" IsChecked="{Binding StartWithWindows}" />
                            <CheckBox Margin="0,0,18,8" Content="Start paused" IsChecked="{Binding StartPaused}" />
                        </WrapPanel>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="2" Header="Per-Monitor Wallpaper Assignment" Padding="14">
                    <ItemsControl ItemsSource="{Binding MonitorAssignments}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center" Text="{Binding FriendlyName}" />
                                    <ComboBox Grid.Column="1"
                                              Margin="12,0,0,0"
                                              ItemsSource="{Binding AvailableWallpapers}"
                                              SelectedItem="{Binding SelectedWallpaper}"
                                              DisplayMemberPath="DisplayName" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </GroupBox>
            </Grid>
        </ScrollViewer>

        <DockPanel Grid.Row="2" Margin="0,16,0,0">
            <TextBlock VerticalAlignment="Center"
                       Foreground="#666666"
                       Text="{Binding StatusMessage}" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Width="120" Margin="0,0,8,0" Content="Refresh" Command="{Binding RefreshCommand}" />
                <Button Width="160" Content="Save, Apply, Hide" Command="{Binding SaveCommand}" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
